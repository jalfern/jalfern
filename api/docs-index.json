export default function handler(req, res) {
  const fs = require('fs');
  const path = require('path');

  try {
    // Read the index file
    const indexPath = path.join(process.cwd(), 'data', 'docs-index.json');
    if (!fs.existsSync(indexPath)) {
      return res.status(404).json({ error: 'No index found' });
    }

    const indexData = JSON.parse(fs.readFileSync(indexPath, 'utf8'));
    const docs = indexData.docs || [];

    if (req.method === 'GET') {
      // Return full docs with content
      if (req.query.full === 'true') {
        const fullDocs = docs.map(doc => {
          const docPath = path.join(process.cwd(), 'data', 'docs', `${doc.id}.md`);
          if (fs.existsSync(docPath)) {
            return { ...doc, content: fs.readFileSync(docPath, 'utf8') };
          }
          return doc;
        });
        return res.status(200).json({ docs: fullDocs });
      } else {
        // Return index only
        return res.status(200).json({ docs });
      }
    }

    return res.status(405).json({ error: 'Method not allowed' });
  } catch (error) {
    return res.status(500).json({ error: 'Failed to read docs', message: error.message });
  }
}
